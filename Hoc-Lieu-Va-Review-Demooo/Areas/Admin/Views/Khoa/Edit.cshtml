@model Hoc_Lieu_Va_Review_Demooo.Models.Khoa

@{
    ViewData["Title"] = "Sửa thông tin Khoa";
}

<div class="container mt-4">
    <h2>Sửa thông tin Khoa</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="KhoaID" />

                <div class="form-group mb-3">
                    <label asp-for="TenKhoa" class="control-label fw-bold">Tên Khoa <span class="text-danger">*</span></label>
                    <input asp-for="TenKhoa" class="form-control" />
                    <span asp-validation-for="TenKhoa" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="MoTa" class="control-label fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    <a class="btn btn-secondary ms-2" asp-action="Index">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}