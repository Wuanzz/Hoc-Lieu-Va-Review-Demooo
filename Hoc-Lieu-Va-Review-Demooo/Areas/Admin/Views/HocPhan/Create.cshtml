@model Hoc_Lieu_Va_Review_Demooo.Models.HocPhan

@{
    ViewData["Title"] = "Thêm Học Phần";
}

<div class="container mt-4">
    <h2>Thêm Học Phần Mới</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold text-primary">Bước 1: Chọn Khoa</label>
                    <select id="KhoaSelect" class="form-select" asp-items="ViewBag.KhoaList">
                        <option value="">-- Vui lòng chọn Khoa --</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="NganhID" class="control-label fw-bold text-success">Bước 2: Chọn Ngành <span class="text-danger">*</span></label>
                    <select asp-for="NganhID" id="NganhSelect" class="form-select">
                        <option value="">-- Vui lòng chọn Khoa trước --</option>
                    </select>
                    <span asp-validation-for="NganhID" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TenHocPhan" class="control-label fw-bold">Tên Học Phần <span class="text-danger">*</span></label>
                    <input asp-for="TenHocPhan" class="form-control" placeholder="Ví dụ: Lập trình Web ASP.NET Core..." />
                    <span asp-validation-for="TenHocPhan" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="MoTa" class="control-label fw-bold">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success">Lưu dữ liệu</button>
                    <a class="btn btn-secondary ms-2" asp-action="Index">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Khi người dùng thay đổi lựa chọn ở ô chọn Khoa
            $('#KhoaSelect').change(function () {
                var khoaId = $(this).val(); // Lấy ID của Khoa vừa chọn
                var nganhSelect = $('#NganhSelect');

                // Xóa dữ liệu cũ của ô chọn Ngành
                nganhSelect.empty();

                if (khoaId) {
                    // Nếu có chọn Khoa, gọi AJAX xuống server
                    $.ajax({
                        url: '/HocPhan/GetNganhByKhoa',
                        type: 'GET',
                        data: { khoaId: khoaId },
                        success: function (data) {
                            // Thêm dòng mặc định
                            nganhSelect.append($('<option/>', {
                                value: "",
                                text: "-- Chọn Ngành --"
                            }));
                            // Đổ dữ liệu JSON trả về vào ô chọn Ngành
                            $.each(data, function (index, item) {
                                nganhSelect.append($('<option/>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                        }
                    });
                } else {
                    // Nếu chọn lại "-- Vui lòng chọn Khoa --" thì reset lại ô chọn Ngành
                    nganhSelect.append($('<option/>', {
                        value: "",
                        text: "-- Vui lòng chọn Khoa trước --"
                    }));
                }
            });
        });
    </script>
}