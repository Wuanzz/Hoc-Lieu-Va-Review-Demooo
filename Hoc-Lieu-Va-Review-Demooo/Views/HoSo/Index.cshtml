@model Hoc_Lieu_Va_Review_Demooo.Models.NguoiDung
@{
    ViewData["Title"] = "Hồ Sơ Của Tôi";
    var taiLieuCuaToi = ViewBag.TaiLieuCuaToi as List<Hoc_Lieu_Va_Review_Demooo.Models.TaiLieu>;
    var reviewCuaToi = ViewBag.ReviewCuaToi as List<Hoc_Lieu_Va_Review_Demooo.Models.Review>;
}

<div class="container mt-4">
    @if (TempData["ThongBaoDoiMatKhau"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>✅ Chúc mừng!</strong> @TempData["ThongBaoDoiMatKhau"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 border-top border-primary border-4 text-center pb-4">
                <div class="card-body">

                    <div class="mb-3 mt-3">
                        @if (!string.IsNullOrEmpty(Model.AnhDaiDien))
                        {
                            <img src="@Model.AnhDaiDien" alt="Avatar" class="rounded-circle object-fit-cover shadow-sm" style="width: 120px; height: 120px; border: 3px solid #0d6efd;" />
                        }
                        else
                        {
                            <span class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 120px; height: 120px; font-size: 3rem; border: 3px solid #0d6efd;">
                                👤
                            </span>
                        }
                    </div>

                    <h4 class="fw-bold">@Model.HoTen</h4>
                    <p class="text-muted mb-1">@Model.Email</p>
                    <div class="mt-2">
                        @if (Model.VaiTro == "Admin")
                        {
                            <span class="badge bg-danger">Quản trị viên</span>
                        }
                        else if (Model.VaiTro == "GiangVien")
                        {

                            <span class="badge bg-warning text-dark">Giảng viên</span>
                        }
                        else
                        {

                            <span class="badge bg-info text-dark">Sinh viên</span>
                        }
                    </div>
                    <hr />
                    <p class="small text-muted mb-0">Tham gia từ: @Model.NgayDangKy.ToString("dd/MM/yyyy")</p>

                    <div class="mt-4 d-flex flex-column gap-2 px-3">
                        <form asp-action="CapNhatAnhDaiDien" method="post" enctype="multipart/form-data" id="formAvatar" class="d-none">
                            <input type="file" name="fileDaiDien" id="fileDaiDien" accept="image/*" onchange="document.getElementById('formAvatar').submit();">
                        </form>

                        <button type="button" class="btn btn-outline-primary btn-sm fw-bold w-100" onclick="document.getElementById('fileDaiDien').click();">
                            🖼️ Thay avatar
                        </button>

                        <a asp-action="DoiMatKhau" class="btn btn-outline-danger btn-sm w-100 fw-bold">🔐 Đổi mật khẩu</a>
                    </div>

                    @if (TempData["ThongBaoHoSo"] != null)
                    {
                        <div class="alert alert-success mt-3 mx-3 py-2 small mb-0">✅ @TempData["ThongBaoHoSo"]</div>
                    }
                    @if (TempData["LoiHoSo"] != null)
                    {
                        <div class="alert alert-danger mt-3 mx-3 py-2 small mb-0">❌ @TempData["LoiHoSo"]</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-success">📄 Tài liệu tôi đã chia sẻ (@taiLieuCuaToi?.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (taiLieuCuaToi != null && taiLieuCuaToi.Any())
                        {
                            foreach (var item in taiLieuCuaToi)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center p-3 position-relative list-group-item-action">
                                    <div>
                                        @if (item.TrangThaiDuyet == "HopLe")
                                        {
                                            <a asp-controller="TaiLieu" asp-action="Details" asp-route-id="@item.TaiLieuID" class="text-decoration-none h6 mb-1 fw-bold text-primary d-block stretched-link">@item.TenTaiLieu</a>
                                        }
                                        else
                                        {
                                            <h6 class="mb-1 fw-bold text-dark">@item.TenTaiLieu</h6>
                                        }
                                        <small class="text-muted">Môn: @item.HocPhan?.TenHocPhan | Ngày: @item.NgayUpload.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div>
                                        @if (item.TrangThaiDuyet == "HopLe")
                                        {
                                            <span class="badge bg-success">Đã duyệt</span>
                                        }
                                        else if (item.TrangThaiDuyet == "ChoDuyet")
                                        {

                                            <span class="badge bg-warning text-dark">Đang chờ</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-danger">Bị từ chối</span>
                                        }
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted text-center py-4">Bạn chưa tải lên tài liệu nào.</li>
                        }
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-warning text-dark">⭐ Đánh giá tôi đã viết (@reviewCuaToi?.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (reviewCuaToi != null && reviewCuaToi.Any())
                        {
                            foreach (var item in reviewCuaToi)
                            {
                                <li class="list-group-item p-3 position-relative list-group-item-action">
                                    <div class="d-flex justify-content-between align-items-start">

                                        <div class="pe-3 w-100">
                                            @if (item.TrangThaiDuyet == "HopLe" || item.TrangThaiDuyet == "DaDuyet")
                                            {
                                                <a asp-controller="Review" asp-action="Details" asp-route-id="@item.ReviewID" class="text-decoration-none h6 mb-1 fw-bold text-primary d-block stretched-link">@item.HocPhan?.TenHocPhan</a>
                                            }
                                            else
                                            {
                                                <h6 class="mb-1 fw-bold text-dark">@item.HocPhan?.TenHocPhan</h6>
                                            }
                                            <p class="mb-0 small text-truncate text-muted" style="max-width: 95%;">"@item.NoiDung"</p>
                                        </div>

                                        <div class="text-end flex-shrink-0" style="min-width: 85px;">
                                            <small class="text-muted d-block mb-1">@item.NgayDang.ToString("dd/MM/yyyy")</small>
                                            @if (item.TrangThaiDuyet == "HopLe" || item.TrangThaiDuyet == "DaDuyet")
                                            {
                                                <span class="badge bg-success">Hiển thị</span>
                                            }
                                            else if (item.TrangThaiDuyet == "ChoDuyet")
                                            {

                                                <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-danger">Bị chặn</span>
                                            }
                                        </div>

                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted text-center py-4">Bạn chưa viết bài đánh giá nào.</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>