@model IEnumerable<Hoc_Lieu_Va_Review_Demooo.Models.Review>

@{
    ViewData["Title"] = "Cộng đồng Review";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Cộng đồng Review Học Phần</h2>
        <a class="btn btn-warning fw-bold text-dark" asp-action="Create">✍️ Viết Review Mới</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-start border-warning border-4">
                        <div class="card-body">
                            <h5 class="card-title text-success fw-bold">@item.HocPhan?.TenHocPhan</h5>
                            <h6 class="card-subtitle mb-2 text-muted">
                                Đăng bởi: <strong>@item.NguoiDung?.HoTen</strong> - @item.NgayDang.ToString("dd/MM/yyyy HH:mm")
                            </h6>
                            <p class="mb-2">
                                @for (int i = 0; i < item.SoSao; i++)
                                {
                                    <span>⭐</span>
                                }
                            </p>
                            <p class="card-text">@item.NoiDung</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Chưa có đánh giá nào. Hãy là người đầu tiên bóc tem môn học nhé!
        </div>
    }
</div>