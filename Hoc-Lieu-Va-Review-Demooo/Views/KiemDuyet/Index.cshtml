@{
    ViewData["Title"] = "Bảng điều khiển Giảng viên";

    var danhSachTaiLieu = ViewBag.TaiLieuChoDuyet as List<Hoc_Lieu_Va_Review_Demooo.Models.TaiLieu>;
    var danhSachBaoCao = ViewBag.DanhSachBaoCao as List<Hoc_Lieu_Va_Review_Demooo.Models.BaoCao>;
    var binhLuanChoDuyet = ViewBag.BinhLuanChoDuyet as List<Hoc_Lieu_Va_Review_Demooo.Models.BinhLuan>;
    var reviewChoDuyet = ViewBag.ReviewChoDuyet as List<Hoc_Lieu_Va_Review_Demooo.Models.Review>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Không gian Kiểm duyệt Nội dung</h2>
    </div>

    <div class="card shadow-sm border-0 border-top border-primary border-4 mb-5">
        <div class="card-header bg-white py-3 d-flex justify-content-between">
            <h5 class="mb-0 text-primary fw-bold">1. Tài Liệu Mới Cần Phê Duyệt</h5>
            <span class="badge bg-primary">Chờ duyệt: @(danhSachTaiLieu?.Count ?? 0)</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tên Tài liệu</th>
                        <th>Môn Học</th>
                        <th>Người đăng</th>
                        <th>Thời gian</th>
                        <th class="text-center">Quyết định</th>
                    </tr>
                </thead>
                <tbody>
                    @if (danhSachTaiLieu != null && danhSachTaiLieu.Any())
                    {
                        foreach (var item in danhSachTaiLieu)
                        {
                            <tr>
                                <td class="fw-bold">
                                    @item.TenTaiLieu
                                    <br /><a href="@item.DuongDanFile" target="_blank" class="text-info small text-decoration-none">🔍 Xem nội dung</a>
                                </td>
                                <td>@item.HocPhan?.TenHocPhan</td>
                                <td>@item.NguoiDung?.HoTen</td>
                                <td>@item.NgayUpload.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <form asp-action="DuyetTaiLieu" method="post">
                                            <input type="hidden" name="id" value="@item.TaiLieuID" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold">✅ Duyệt</button>
                                        </form>
                                        <form asp-action="TuChoiTaiLieu" method="post">
                                            <input type="hidden" name="id" value="@item.TaiLieuID" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">❌ Từ chối</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-success fw-bold">Không có tài liệu nào chờ duyệt.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 border-top border-danger border-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between">
            <h5 class="mb-0 text-danger fw-bold">2. Tài Liệu Cần Xử Lý</h5>
            <span class="badge bg-danger">Chờ xử lý: @(danhSachBaoCao?.Count ?? 0)</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tài liệu bị báo cáo</th>
                        <th>Lý do vi phạm</th>
                        <th>Người báo cáo</th>
                        <th>Thời gian</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (danhSachBaoCao != null && danhSachBaoCao.Any())
                    {
                        foreach (var item in danhSachBaoCao)
                        {
                            <tr>
                                <td class="fw-bold text-danger">
                                    @item.TaiLieu?.TenTaiLieu
                                    <br /><a href="@item.TaiLieu?.DuongDanFile" target="_blank" class="text-info small text-decoration-none">🔍 Kiểm tra file</a>
                                </td>
                                <td class="text-wrap" style="max-width: 250px;">@item.LyDo</td>
                                <td>@item.NguoiDung?.HoTen</td>
                                <td>@item.NgayBaoCao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button" class="btn btn-sm btn-danger fw-bold" data-bs-toggle="modal" data-bs-target="#modalAnTaiLieu_@item.BaoCaoID">
                                            🗑️ Ẩn tài liệu
                                        </button>

                                        <div class="modal fade text-start" id="modalAnTaiLieu_@item.BaoCaoID" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content border-danger">
                                                    <div class="modal-header bg-danger text-white">
                                                        <h5 class="modal-title fw-bold">⚠️ Xác nhận Ẩn Tài Liệu</h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body text-dark text-wrap">
                                                        <p>Bạn có chắc chắn muốn ẩn tài liệu <strong class="text-danger">@item.TaiLieu?.TenTaiLieu</strong> khỏi hệ thống không?</p>
                                                        <p class="text-muted small mb-0">Hành động này sẽ khiến sinh viên không thể nhìn thấy hay tải xuống tài liệu này nữa.</p>
                                                    </div>
                                                    <div class="modal-footer bg-light">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                                                        <form asp-action="XoaTaiLieuViPham" method="post">
                                                            <input type="hidden" name="id" value="@item.BaoCaoID" />
                                                            <button type="submit" class="btn btn-danger fw-bold">Xác nhận Ẩn</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <form asp-action="BoQuaBaoCao" method="post">
                                            <input type="hidden" name="id" value="@item.BaoCaoID" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary fw-bold">👁️ Bỏ qua</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-success fw-bold">Không có tài liệu nào bị báo cáo. Kho tài liệu đang rất được hài lòng!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 border-top border-warning border-4 mt-5">
        <div class="card-header bg-white py-3 d-flex justify-content-between">
            <h5 class="mb-0 text-warning fw-bold text-dark">3. Bình Luận Bị AI Cảnh Báo</h5>
            <span class="badge bg-warning text-dark">Chờ duyệt: @(binhLuanChoDuyet?.Count ?? 0)</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40%">Nội dung bình luận</th>
                        <th>Tại tài liệu</th>
                        <th>Người đăng</th>
                        <th>Thời gian</th>
                        <th class="text-center">Quyết định</th>
                    </tr>
                </thead>
                <tbody>
                    @if (binhLuanChoDuyet != null && binhLuanChoDuyet.Any())
                    {
                        foreach (var item in binhLuanChoDuyet)
                        {
                            <tr>
                                <td class="fw-bold text-dark fst-italic">"@item.NoiDung"</td>
                                <td>
                                    <a asp-controller="TaiLieu" asp-action="Details" asp-route-id="@item.TaiLieuID" target="_blank" class="text-decoration-none">
                                        @item.TaiLieu?.TenTaiLieu
                                    </a>
                                </td>
                                <td>@item.NguoiDung?.HoTen</td>
                                <td>@item.NgayDang.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <form asp-action="DuyetBinhLuan" method="post">
                                            <input type="hidden" name="id" value="@item.BinhLuanID" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold">✅ Cho phép</button>
                                        </form>

                                        <form asp-action="TuChoiBinhLuan" method="post">
                                            <input type="hidden" name="id" value="@item.BinhLuanID" />
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold">❌ Chặn</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-success fw-bold">AI đã xử lý tốt, không có bình luận nào cần phải duyệt!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 border-top border-info border-4 mt-5 mb-5">
        <div class="card-header bg-white py-3 d-flex justify-content-between">
            <h5 class="mb-0 text-info fw-bold text-dark">4. Bài Đánh Giá Bị AI Cảnh Báo</h5>
            <span class="badge bg-info text-dark">Chờ duyệt: @(reviewChoDuyet?.Count ?? 0)</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40%">Nội dung đánh giá</th>
                        <th>Môn học</th>
                        <th>Người đăng</th>
                        <th>Số sao</th>
                        <th class="text-center">Quyết định</th>
                    </tr>
                </thead>
                <tbody>
                    @if (reviewChoDuyet != null && reviewChoDuyet.Any())
                    {
                        foreach (var item in reviewChoDuyet)
                        {
                            <tr>
                                <td class="fw-bold text-dark fst-italic">"@item.NoiDung"</td>
                                <td>@item.HocPhan?.TenHocPhan</td>
                                <td>@item.NguoiDung?.HoTen</td>
                                <td>
                                    @for (int i = 0; i < item.SoSao; i++)
                                    {
                                        <span class="text-warning">⭐</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <form asp-action="DuyetReview" method="post">
                                            <input type="hidden" name="id" value="@item.ReviewID" />
                                            <button type="submit" class="btn btn-sm btn-success fw-bold">✅ Cho phép</button>
                                        </form>

                                        <form asp-action="TuChoiReview" method="post">
                                            <input type="hidden" name="id" value="@item.ReviewID" />
                                            <button type="submit" class="btn btn-sm btn-danger fw-bold">❌ Chặn</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-success fw-bold">Không có bài đánh giá nào cần duyệt. AI đã lo liệu hết!</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>