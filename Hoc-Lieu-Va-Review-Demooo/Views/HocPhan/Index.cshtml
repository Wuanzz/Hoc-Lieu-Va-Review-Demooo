@model IEnumerable<Hoc_Lieu_Va_Review_Demooo.Models.HocPhan>

@{
    ViewData["Title"] = "Quản lý Học Phần";
}

<div class="container mt-4">
    <h2 class="mb-4">Danh sách Học Phần</h2>

    <div class="row mb-3 mt-3">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="timKiem" class="form-control" placeholder="Nhập tên học phần cần tìm..." value="@ViewBag.TuKhoa">
                <button type="submit" class="btn btn-primary fw-bold">Tìm</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa</a>
            </form>
        </div>
    </div>

    <p>
        <a class="btn btn-success" asp-action="Create">Thêm Học Phần mới</a>
    </p>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>STT</th>
                <th>Tên Học Phần</th>
                <th>Thuộc Ngành</th>
                <th>Mô tả</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int stt = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@stt</td>
                        <td class="fw-bold text-success">@item.TenHocPhan</td>

                        <td>@item.Nganh?.TenNganh</td>

                        <td>@item.MoTa</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.HocPhanID">Sửa</a> |
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.HocPhanID">Xóa</a>
                        </td>
                    </tr>
                    stt++;
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">Chưa có dữ liệu Học Phần nào trong hệ thống.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold text-primary" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-timKiem="@ViewBag.TuKhoa">&laquo; Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == 1 || i == ViewBag.TotalPages || Math.Abs(i - ViewBag.CurrentPage) <= 1)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link fw-bold" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-timKiem="@ViewBag.TuKhoa">@i</a>
                    </li>
                }
                else if (i == 2 && ViewBag.CurrentPage > 3)
                {
                    <li class="page-item disabled"><span class="page-link text-muted fw-bold">...</span></li>
                }
                else if (i == ViewBag.TotalPages - 1 && ViewBag.CurrentPage < ViewBag.TotalPages - 2)
                {
                    <li class="page-item disabled"><span class="page-link text-muted fw-bold">...</span></li>
                }
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold text-primary" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-timKiem="@ViewBag.TuKhoa">Sau &raquo;</a>
            </li>

        </ul>
    </nav>
}