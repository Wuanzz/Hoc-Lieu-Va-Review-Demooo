@model Hoc_Lieu_Va_Review_Demooo.Models.Nganh

@{
    ViewData["Title"] = "Thêm Ngành Mới";
}

<div class="container mt-4">
    <h2>Thêm Ngành Mới</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="KhoaID" class="control-label fw-bold">Thuộc Khoa <span class="text-danger">*</span></label>
                    <select asp-for="KhoaID" class="form-control" asp-items="ViewBag.KhoaID">
                        <option value="">-- Chọn Khoa --</option>
                    </select>
                    <span asp-validation-for="KhoaID" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TenNganh" class="control-label fw-bold">Tên Ngành <span class="text-danger">*</span></label>
                    <input asp-for="TenNganh" class="form-control" placeholder="Nhập tên ngành..." />
                    <span asp-validation-for="TenNganh" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="MoTa" class="control-label fw-bold">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success">Lưu dữ liệu</button>
                    <a class="btn btn-secondary ms-2" asp-action="Index">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}