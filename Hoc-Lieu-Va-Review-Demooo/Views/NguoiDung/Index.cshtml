@model IEnumerable<Hoc_Lieu_Va_Review_Demooo.Models.NguoiDung>

@{
    ViewData["Title"] = "Quản lý Tài Khoản";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Quản lý Người Dùng</h2>
        <span class="badge bg-primary fs-6">Tổng số: @Model.Count() tài khoản</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày đăng ký</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.HoTen</td>
                            <td>@item.Email</td>
                            <td>
                                @if (item.VaiTro == "Admin")
                                {
                                    <span class="badge bg-danger">@item.VaiTro</span>
                                }
                                else if (item.VaiTro == "GiangVien")
                                {

                                    <span class="badge bg-warning text-dark">@item.VaiTro</span>
                                }
                                else
                                {

                                    <span class="badge bg-info text-dark">@item.VaiTro</span>
                                }
                            </td>
                            <td>
                                @if (item.TrangThai == "HoatDong" || item.TrangThai == "Hoạt động")
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã khóa</span>
                                }
                            </td>
                            <td>@item.NgayDangKy.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.NguoiDungID">Cấp quyền / Khóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>