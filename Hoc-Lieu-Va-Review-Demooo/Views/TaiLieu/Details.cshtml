@model Hoc_Lieu_Va_Review_Demooo.Models.TaiLieu

@{
    ViewData["Title"] = "Chi tiết Tài liệu";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@Model.TenTaiLieu</h2>
        <a class="btn btn-secondary" asp-action="Index">Quay lại danh sách</a>
    </div>

    @if (TempData["ThongBaoBaoCao"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>✅ Thành công!</strong> @TempData["ThongBaoBaoCao"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📄 Xem trước tài liệu</h5>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(Model.DuongDanFile) && Model.DuongDanFile.EndsWith(".pdf"))
                    {
                        <iframe src="@Model.DuongDanFile" width="100%" height="600px" style="border: none;"></iframe>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <h5 class="text-muted">Chức năng xem trước hiện chỉ hỗ trợ file PDF.</h5>
                            <p>Vui lòng tải về để xem nội dung file Word/PowerPoint/Zip.</p>
                            <a class="btn btn-success" asp-action="Download" asp-route-id="@Model.TaiLieuID">Tải về máy (@Model.LuotTai lượt tải)</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body bg-light">
                    <p class="mb-1"><strong>Môn học:</strong> <span class="text-success">@Model.HocPhan?.TenHocPhan</span></p>
                    <p class="mb-1"><strong>Người đăng:</strong> @Model.NguoiDung?.HoTen</p>
                    <p class="mb-1"><strong>Dung lượng:</strong> @Model.KichThuoc MB</p>
                    <p class="mb-1"><strong>Lượt tải:</strong> @Model.LuotTai</p>
                    <div class="mt-3">
                        <a class="btn btn-success w-100" asp-action="Download" asp-route-id="@Model.TaiLieuID">Tải xuống ngay</a>
                        <button type="button" class="btn btn-outline-danger w-100 mt-2 fw-bold" data-bs-toggle="modal" data-bs-target="#modalBaoCao">
                            🚩 Báo cáo vi phạm
                        </button>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">💬 Thảo luận (@(Model.BinhLuans?.Count() ?? 0))</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AddComment" method="post" class="mb-4">
                        <input type="hidden" name="TaiLieuID" value="@Model.TaiLieuID" />
                        <div class="input-group">
                            <input type="text" name="NoiDung" class="form-control" placeholder="Nhập bình luận của bạn..." required />
                            <button class="btn btn-primary" type="submit">Gửi</button>
                        </div>
                    </form>

                    <div class="comment-list" style="max-height: 400px; overflow-y: auto;">
                        @if (Model.BinhLuans != null && Model.BinhLuans.Any())
                        {
                            foreach (var cmt in Model.BinhLuans)
                            {
                                <div class="mb-3 border-bottom pb-2">
                                    <strong class="text-primary">@cmt.NguoiDung?.HoTen</strong>
                                    <small class="text-muted ms-2">@cmt.NgayDang.ToString("dd/MM HH:mm")</small>
                                    <p class="mb-0 mt-1">@cmt.NoiDung</p>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted text-center fst-italic">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalBaoCao" tabindex="-1" aria-labelledby="modalBaoCaoLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-danger border-2">
            <form asp-controller="BaoCao" asp-action="GuiBaoCao" method="post">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold" id="modalBaoCaoLabel">🚩 Báo cáo Tài liệu vi phạm</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="TaiLieuID" value="@Model.TaiLieuID" />

                    <div class="alert alert-warning small">
                        Bạn đang báo cáo tài liệu: <strong>@Model.TenTaiLieu</strong>. <br />
                        Cố tình báo cáo sai sự thật nhiều lần có thể dẫn đến khóa tài khoản.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Lý do báo cáo: <span class="text-danger">*</span></label>
                        <textarea name="LyDo" class="form-control" rows="3" required placeholder="Ví dụ: Tài liệu bị mờ, không đúng môn học, chứa nội dung nhạy cảm..."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-danger fw-bold">Gửi Báo Cáo</button>
                </div>
            </form>
        </div>
    </div>
</div>