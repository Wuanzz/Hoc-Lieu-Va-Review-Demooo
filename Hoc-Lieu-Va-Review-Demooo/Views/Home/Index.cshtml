@{
    ViewData["Title"] = "Trang Chủ";

    // Ép kiểu dữ liệu từ ViewBag
    var taiLieuMoi = ViewBag.TaiLieuMoi as List<Hoc_Lieu_Va_Review_Demooo.Models.TaiLieu>;
    var reviewMoi = ViewBag.ReviewMoi as List<Hoc_Lieu_Va_Review_Demooo.Models.Review>;
}

<div class="p-5 mb-5 bg-light rounded-3 shadow-sm border-bottom border-primary border-5" style="background: linear-gradient(to right, #f8f9fa, #e9ecef);">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold text-primary">Kho Học Liệu & Đánh Giá Môn Học</h1>
        <p class="col-md-8 fs-5 mt-3">
            Nền tảng giúp bạn dễ dàng tìm kiếm đề thi, slide bài giảng và đọc những đánh giá chân thực nhất về các môn học. Hãy cùng xây dựng cộng đồng học tập vững mạnh!
        </p>
        <div class="mt-4">
            <a class="btn btn-primary btn-lg fw-bold px-4" asp-controller="TaiLieu" asp-action="Index">📚 Khám phá Tài Liệu</a>
            <a class="btn btn-outline-warning btn-lg ms-2 fw-bold text-dark px-4" asp-controller="Review" asp-action="Index">⭐ Đọc Review</a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="text-success fw-bold m-0">📄 Tài Liệu Mới Cập Nhật</h4>
            <a asp-controller="TaiLieu" asp-action="Index" class="text-decoration-none small fw-bold">Xem tất cả &rarr;</a>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-3">
            @if (taiLieuMoi != null && taiLieuMoi.Any())
            {
                foreach (var item in taiLieuMoi)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 border-start border-success border-4">
                            <div class="card-body">
                                <h5 class="card-title text-truncate fw-bold" title="@item.TenTaiLieu">@item.TenTaiLieu</h5>
                                <h6 class="card-subtitle mb-2 text-muted small">Môn: @item.HocPhan?.TenHocPhan</h6>
                                <div class="mt-3 text-dark small bg-light p-2 rounded">
                                    <span>👤 Đăng bởi: <strong>@item.NguoiDung?.HoTen</strong></span> <br />
                                    <span class="text-muted">📅 @item.NgayUpload.ToString("dd/MM/yyyy") | 💾 @item.KichThuoc MB</span>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-0 pt-0">
                                <a class="btn btn-sm btn-outline-success w-100 fw-bold" asp-controller="TaiLieu" asp-action="Details" asp-route-id="@item.TaiLieuID">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><div class="alert alert-info">Chưa có tài liệu nào trên hệ thống.</div></div>
            }
        </div>
    </div>

    <div class="col-md-4 mt-4 mt-md-0">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="text-warning fw-bold m-0 text-dark">⭐ Review Gần Đây</h4>
        </div>

        <div class="list-group shadow-sm border-0">
            @if (reviewMoi != null && reviewMoi.Any())
            {
                foreach (var item in reviewMoi)
                {
                    <div class="list-group-item list-group-item-action border-0 border-bottom p-3">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-primary">@item.HocPhan?.TenHocPhan</h6>
                            <small class="text-muted">@item.NgayDang.ToString("dd/MM")</small>
                        </div>
                        <p class="mb-2 small text-truncate text-muted">"@item.NoiDung"</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small>
                                @for (int i = 0; i < item.SoSao; i++)
                                {
                                    <span class="text-warning">⭐</span>
                                }
                            </small>
                            <small class="fw-bold text-secondary">@item.NguoiDung?.HoTen</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-3 text-muted fst-italic border rounded bg-white">Chưa có đánh giá nào.</div>
            }
        </div>
    </div>
</div>