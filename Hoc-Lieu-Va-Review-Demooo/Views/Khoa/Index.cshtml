@model IEnumerable<Hoc_Lieu_Va_Review_Demooo.Models.Khoa>

@{
    ViewData["Title"] = "Quản lý Khoa";
}

<div class="container mt-4">
    <h2 class="mb-4">Danh sách các Khoa</h2>

    <p>
        <a class="btn btn-success" asp-action="Create">Thêm Khoa mới</a>
    </p>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>STT</th>
                <th>Tên Khoa</th>
                <th>Mô tả</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int stt = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@stt</td>
                        <td>@item.TenKhoa</td>
                        <td>@item.MoTa</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@item.KhoaID">Sửa</a> |
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.KhoaID">Xóa</a>
                        </td>
                    </tr>
                    stt++;
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Chưa có dữ liệu Khoa nào trong hệ thống.</td>
                </tr>
            }
        </tbody>
    </table>
</div>